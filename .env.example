# Supabase est la source de vérité des interventions.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Signe les sessions admin JWT.
# Exemple de génération : openssl rand -base64 32
JWT_SECRET=

# Identifiants admin. Le hash est généré avec bcrypt depuis le mot de passe en clair.
# Exemple de génération du hash en local :
#   node -e "console.log(require('bcryptjs').hashSync('VOTRE_MOT_DE_PASSE', 10))"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
